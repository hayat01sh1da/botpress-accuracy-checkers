# frozen_string_literal: true

D = Steep::Diagnostic

# Rails framework signatures come from the RBS collection (rbs_collection.yaml),
# Rails route helpers from sig/rbs_rails (generated by `rake rbs_rails:all`),
# and application code from sig/generated (generated by rbs-inline).
#
# `app` and `spec` are separate targets so the permissive RSpec DSL shim
# (sig/rspec) only relaxes the specs, never the application code.

target :app do
  check 'app'

  signature 'sig/generated/app'
  signature 'sig/rbs_rails'
  signature 'sig/handwritten'

  library 'json'
  library 'net-http'

  configure_code_diagnostics(D::Ruby.default)
end

target :spec do
  check 'spec'

  signature 'sig/generated'
  signature 'sig/rbs_rails'
  signature 'sig/handwritten'
  signature 'sig/rspec'

  library 'json'
  library 'net-http'

  configure_code_diagnostics(D::Ruby.default)
end
